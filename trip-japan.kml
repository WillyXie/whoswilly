<?xml version="1.0" encoding="UTF-8"?>
<kml xmlns="http://www.opengis.net/kml/2.2">
  <Document>
    <name>Trip to Japan</name>
    <description>My travel route and stops in Japan</description>

    <!-- Placemark 1: Tokyo -->
    <Placemark>
      <name>Tokyo (Shinjuku)</name>
      <description>Starting our trip here. Visited the Metropolitan Government Building and Shinjuku Gyoen National Garden.</description>
      <Point>
        <coordinates>139.7003,35.6895,0</coordinates>
      </Point>
    </Placemark>

    <!-- Placemark 2: Mount Fuji -->
    <Placemark>
      <name>Mount Fuji (5th Station)</name>
      <description>Beautiful views of the peak and surrounding lakes.</description>
      <Point>
        <coordinates>138.7278,35.3606,0</coordinates>
      </Point>
    </Placemark>

    <!-- Placemark 3: Kyoto -->
    <Placemark>
      <name>Kyoto (Fushimi Inari)</name>
      <description>Famous for its thousands of vermilion torii gates.</description>
      <Point>
        <coordinates>135.7727,34.9671,0</coordinates>
      </Point>
    </Placemark>

    <!-- Placemark 4: Osaka -->
    <Placemark>
      <name>Osaka Castle</name>
      <description>Historical landmark and park in the center of Osaka.</description>
      <Point>
        <coordinates>135.5262,34.6873,0</coordinates>
      </Point>
    </Placemark>

    <!-- Route: Tokyo to Osaka Tokaido Shinkansen Route -->
    <Placemark>
      <name>Tokaido Shinkansen Route</name>
      <description>High-speed rail journey from Tokyo to Osaka via Kyoto.</description>
      <LineString>
        <tessellate>1</tessellate>
        <coordinates>
          139.7003,35.6895,0
          138.7278,35.3606,0
          135.7727,34.9671,0
          135.5262,34.6873,0
        </coordinates>
      </LineString>
    </Placemark>
  </Document>
</kml>
